<Window x:Class="TherapyTime.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About TherapyTime" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="TherapyTime" FontSize="28" FontWeight="Bold" Foreground="#1F2937"/>

        <Border Grid.Row="1" Margin="0,16,0,16" Padding="14" Background="White" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Developer" FontSize="12" Foreground="#6B7280"/>
                <TextBlock Text="Dakota Stephens" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,12"/>

                <TextBlock Text="Company" FontSize="12" Foreground="#6B7280"/>
                <TextBlock Text="Nerd Brothers LLC" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,12"/>

                <TextBlock Text="Version" FontSize="12" Foreground="#6B7280"/>
                <TextBlock x:Name="VersionText" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Width="96" Height="32" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
