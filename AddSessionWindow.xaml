<Window x:Class="TherapyTime.AddSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Session" Height="300" Width="400" MinHeight="300" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Student -->
            <RowDefinition Height="Auto"/> <!-- Date -->
            <RowDefinition Height="Auto"/> <!-- Minutes -->
            <RowDefinition Height="Auto"/> <!-- Session Code -->
            <RowDefinition Height="*"/>    <!-- Spacer / Buttons at bottom -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Student -->
        <Label Grid.Row="0" Grid.Column="0" Content="Student:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="StudentComboBox" Margin="5"/>

        <!-- Date -->
        <Label Grid.Row="1" Grid.Column="0" Content="Date:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="SessionDatePicker" Margin="5"/>

        <!-- Minutes -->
        <Label Grid.Row="2" Grid.Column="0" Content="Minutes:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="MinutesComboBox" Margin="5"/>

        <!-- Session Code -->
        <Label Grid.Row="3" Grid.Column="0" Content="Session Code:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="SessionCodeComboBox" Margin="5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Add" Width="80" Margin="5" Click="Add_Click"/>
            <Button Content="Cancel" Width="80" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>