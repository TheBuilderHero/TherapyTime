<Window x:Class="TherapyTime.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Student" Height="600" Width="540" MinHeight="560" MinWidth="520"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="1" Content="?" Width="28" Height="28"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,6,0"
            Click="HelpBubble_Click"
            ToolTip="Show help for this window"
            FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>

        <Label Grid.Row="1" Grid.Column="0" Content="First Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FirstNameTextBox" Margin="6" MinWidth="220"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Last Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="LastNameTextBox" Margin="6" MinWidth="220"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Required Minutes:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="RequiredMinutesTextBox" Margin="6" Text="120"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Future Annual Review:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="4" Grid.Column="1" x:Name="FutureAnnualReviewPicker" Margin="6"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Next 3-Year Reevaluation:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="5" Grid.Column="1" x:Name="NextThreeYearReevaluationPicker" Margin="6"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Main Contact Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="MainContactNameTextBox" Margin="6" MinWidth="220"/>

        <Label Grid.Row="7" Grid.Column="0" Content="Main Contact Phone:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="MainContactPhoneTextBox" Margin="6"/>

        <Label Grid.Row="8" Grid.Column="0" Content="Main Contact Email:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="8" Grid.Column="1" x:Name="MainContactEmailTextBox" Margin="6"/>

        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="6,0,6,6">
            <CheckBox x:Name="PreferPhoneCheckBox" Content="Prefer Phone" Margin="0,0,12,0"/>
            <CheckBox x:Name="PreferEmailCheckBox" Content="Prefer Email"/>
        </StackPanel>

        <CheckBox Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" x:Name="AddPastAnnualReviewCheckBox"
                  Margin="6,10,6,0" Content="Add Past Annual Review"
                  Checked="AddPastAnnualReviewCheckBox_Changed"
                  Unchecked="AddPastAnnualReviewCheckBox_Changed"/>

        <StackPanel Grid.Row="11" Grid.Column="1" Margin="0,6,0,0">
            <Label Content="Past Annual Review:" VerticalAlignment="Center" Padding="0"/>
            <DatePicker x:Name="PastAnnualReviewPicker" Margin="0,4,6,0" IsEnabled="False"/>
            <TextBlock Text="Optional. Leave unchecked if there is no past annual review to add."
                       Margin="0,6,6,0" Foreground="#6B7280" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Add" Width="88" Margin="6,0,0,0" Click="Add_Click"/>
            <Button Content="Cancel" Width="88" Margin="6,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>