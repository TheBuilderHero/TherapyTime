<Window x:Class="TherapyTime.DayView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TherapyTime" Height="600" Width="800" Background="#F5F7FA">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="?" Width="28" Height="28"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,8"
            Click="HelpBubble_Click"
            ToolTip="Show help for this window"
            FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>
        <DataGrid Grid.Row="1" x:Name="userDataGrid" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeaderWidth="0"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <!-- Standard Text Columns -->
                <DataGridTextColumn Header="Student Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Minutes Completed" Binding="{Binding CurrentMonthMinutes}" Width="150" />
                
                <!-- Specialized Dates -->
                <DataGridTextColumn Header="Next Reevaluation" 
                                    Binding="{Binding NextThreeYearReevaluation, StringFormat=\{0:MM/dd/yyyy\}}" 
                                    Width="150" />

                <!-- Buttons for interaction -->
                <DataGridTemplateColumn Header="Actions" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Meeting Complete" Padding="5,2" Click="MeetingComplete_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>