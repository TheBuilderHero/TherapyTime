<Window x:Class="TherapyTime.EditDaySessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TherapyTime"
        Title="Edit Sessions" Height="400" Width="800" MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

        <Window.Resources>
            <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type sys:Enum}" x:Key="SessionCodesProvider" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="local:SessionCode"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <Style x:Key="SessionComboBoxStyle" TargetType="ComboBox">
                <Setter Property="IsEnabled" Value="True"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                        <Setter Property="Opacity" Value="0.5"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Window.Resources>
    <DockPanel Margin="10">

        <DataGrid x:Name="SessionsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  DockPanel.Dock="Top"
                  Margin="0,0,0,10"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  RowEditEnding="SessionsGrid_RowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student Name" Binding="{Binding Student.Name}" IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Time" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TimeDisplay}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox
                                ItemsSource="{Binding TimeItems}"
                                SelectedItem="{Binding TimeOfDay, Mode=TwoWay}"
                                Style="{StaticResource SessionComboBoxStyle}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridComboBoxColumn Header="Minutes"
                                        SelectedItemBinding="{Binding Minutes, Mode=TwoWay}"
                                        ElementStyle="{StaticResource SessionComboBoxStyle}"
                                        EditingElementStyle="{StaticResource SessionComboBoxStyle}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:Int32" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:Int32>5</sys:Int32>
                            <sys:Int32>10</sys:Int32>
                            <sys:Int32>15</sys:Int32>
                            <sys:Int32>20</sys:Int32>
                            <sys:Int32>25</sys:Int32>
                            <sys:Int32>30</sys:Int32>
                            <sys:Int32>35</sys:Int32>
                            <sys:Int32>40</sys:Int32>
                            <sys:Int32>45</sys:Int32>
                            <sys:Int32>50</sys:Int32>
                            <sys:Int32>55</sys:Int32>
                            <sys:Int32>60</sys:Int32>
                            <sys:Int32>65</sys:Int32>
                            <sys:Int32>70</sys:Int32>
                            <sys:Int32>75</sys:Int32>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTemplateColumn Header="Session Code" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Code}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox
                                ItemsSource="{Binding SessionCodeItems}"
                                DisplayMemberPath="DisplayText"
                                SelectedValuePath="Code"
                                SelectedValue="{Binding Code, Mode=TwoWay}"
                                Style="{StaticResource SessionComboBoxStyle}"
                                Margin="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Action" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ActionButtonText}" Padding="5,2" Click="ToggleComplete_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLinkedToMu}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Delete" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete" Padding="5,2" Click="DeleteSession_Click" Background="Red" Foreground="White">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Notes" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Notes" Padding="5,2" Click="NotesSession_Click" Background="LightBlue" Foreground="Black"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel Changes"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="CancelChanges_Click"/>
            <Button Content="Add Session"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="AddSession_Click"/>
                <Button Content="Save Sessions"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="SaveSessions_Click"/>
                <Button Content="Save and Exit"
                    Width="120"
                    Height="30"
                    Click="Save_Click"/>
        </StackPanel>
    </DockPanel>
</Window>