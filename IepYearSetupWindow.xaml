<Window x:Class="TherapyTime.IepYearSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure IEP Year" Height="700" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Configure All 12 IEP Months"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="School Year (Start Year):" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="SchoolYearTextBox" Width="120" Height="30" VerticalContentAlignment="Center"/>
            <Button Content="Load Defaults (Aug-Jul)" Margin="16,0,0,0" Height="30" Padding="12,0" Click="LoadDefaults_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="2"
                  x:Name="MonthsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IEP Month" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                <DataGridTemplateColumn Header="Start Date" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="End Date" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="100" Height="34" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="100" Height="34" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
