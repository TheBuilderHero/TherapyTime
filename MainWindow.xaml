<Window x:Class="TherapyTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TherapyTime" Height="700" Width="800" Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="Auto"/>  <!-- Help -->
            <RowDefinition Height="*"/>     <!-- Calendar Content -->
        </Grid.RowDefinitions>

        <Button Grid.Row="1" Content="?" Width="28" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,10,6"
                Click="HelpBubble_Click"
                ToolTip="Show help for this window"
                FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="New/Open IEP Year" Click="NewIEP_Click"/>
                <MenuItem Header="Save IEP Year" Click="SaveIEP_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Student">
                <MenuItem Header="Add Session" Click="AddSession_Click" />
                <Separator/>
                <MenuItem Header="New Student" Click="NewStudent_Click"/>
                <MenuItem Header="Update Required Minutes" x:Name="UpdateRequiredMinutesMenu"/>
                <MenuItem Header="Archive Student" x:Name="ArchiveStudentMenu"/>
                <MenuItem Header="Unarchive Student" x:Name="UnarchiveStudentMenu"/>
                <MenuItem Header="Delete Student" x:Name="DeleteStudentMenu"/>
            </MenuItem>

            <MenuItem Header="_Statistics">
                <MenuItem Header="Student Minutes and Sessions (Current IEP Year)" Click="ShowStudentStatistics_Click"/>
                <MenuItem Header="Daily View (Current IEP Year)" Click="ShowDailyView_Click"/>
                <MenuItem Header="Review and Reevaluation Dates" Click="ShowReviewDates_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="Documentation" Click="Documentation_Click"/>
                <MenuItem Header="Report Issue" Click="ReportIssue_Click"/>
                <Separator/>
                <MenuItem Header="About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Calendar -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" Width="600">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="IEP Month:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="IepMonthComboBox" Width="320" SelectionChanged="IepMonthComboBox_SelectionChanged"/>
            </StackPanel>

            <!-- Day Headers -->
            <UniformGrid Columns="7" Height="30" Margin="0,0,0,5">
                <TextBlock Text="Sun" HorizontalAlignment="Center"/>
                <TextBlock Text="Mon" HorizontalAlignment="Center"/>
                <TextBlock Text="Tue" HorizontalAlignment="Center"/>
                <TextBlock Text="Wed" HorizontalAlignment="Center"/>
                <TextBlock Text="Thu" HorizontalAlignment="Center"/>
                <TextBlock Text="Fri" HorizontalAlignment="Center"/>
                <TextBlock Text="Sat" HorizontalAlignment="Center"/>
            </UniformGrid>

            <!-- Calendar Grid -->
            <UniformGrid x:Name="panelGrid" Columns="7" />
        </StackPanel>
    </Grid>
</Window>