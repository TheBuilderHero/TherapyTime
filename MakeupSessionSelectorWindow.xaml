<Window x:Class="TherapyTime.MakeupSessionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Makeup Session" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="?" Width="28" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,6"
            Click="HelpBubble_Click"
            ToolTip="Show help for this window"
            FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>
        <ListBox Grid.Row="1" x:Name="SessionsList" Margin="10,0,10,10" DisplayMemberPath="DisplayText"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10">
            <Button Content="OK" Width="80" Margin="5" Click="OK_Click" />
            <Button Content="Cancel" Width="80" Margin="5" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>