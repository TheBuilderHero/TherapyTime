<Window x:Class="TherapyTime.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Current IEP Statistics"
        Height="640"
        Width="980"
        MinHeight="500"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="?" Width="28" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0"
                Click="HelpBubble_Click"
                ToolTip="Show help for this window"
                FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Student Minutes and Sessions" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                <TextBlock Text="Current IEP range" FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
                <TextBlock x:Name="RangeText" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="StudentStatsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="False" Margin="0,0,0,10" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1">
                            <Expander.Header>
                                <Border Padding="10,8,10,8" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding StudentName}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       DockPanel.Dock="Left"/>
                                            <Border Background="{Binding StatusBrush}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                                <TextBlock Text="{Binding StatusText}" Foreground="#111827" FontWeight="SemiBold"/>
                                            </Border>
                                        </DockPanel>

                                        <WrapPanel Margin="0,8,0,0" ItemHeight="24">
                                            <TextBlock Text="{Binding NeededMinutesText}" Margin="0,0,16,0" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                                            <TextBlock Text="{Binding RequiredTimeText}" Margin="0,0,16,0" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                                            <TextBlock Text="{Binding CompletedMinutesText}" Margin="0,0,16,0" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                                            <TextBlock Text="{Binding ScheduledMinutesText}" Margin="0,0,16,0" FontSize="13" FontWeight="Bold" Foreground="{Binding ScheduledMinutesBrush}"/>
                                            <TextBlock Text="{Binding ExcusedMinutesText}" Margin="0,0,16,0" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                                            <TextBlock Text="{Binding RemainingMinutesText}" Margin="0,0,16,0" FontSize="13" FontWeight="Bold" Foreground="#1F2937"/>
                                            <TextBlock Text="{Binding TherapyBalanceText}" FontSize="13" FontWeight="Bold" Foreground="{Binding TherapyBalanceBrush}"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Expander.Header>

                            <Border Margin="10,4,10,10" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                                <DataGrid ItemsSource="{Binding Sessions}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0"
                                          MinHeight="120">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="1.1*"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="1.1*"/>
                                        <DataGridTextColumn Header="Minutes" Binding="{Binding Minutes}" Width="0.8*"/>
                                        <DataGridTextColumn Header="Code" Binding="{Binding CodeText}" Width="0.8*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding CompletionStatusText}" Width="1.2*"/>
                                    </DataGrid.Columns>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="{Binding RowBackground}"/>
                                            <Setter Property="Foreground" Value="#111827"/>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
