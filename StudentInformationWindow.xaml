<Window x:Class="TherapyTime.StudentInformationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Information" Height="700" Width="980"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" Background="White" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel>
                <TextBlock Text="Students" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                <ListBox x:Name="StudentListBox" DisplayMemberPath="Name" SelectionChanged="StudentListBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0" Background="White" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="View/Update Student Information" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="First Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="FirstNameTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Last Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="LastNameTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Monthly Required Minutes:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="RequiredMinutesTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <CheckBox x:Name="ArchivedCheckBox" Content="Archived" Margin="0,6,0,6"/>

                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="Main Contact (Optional)" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Contact Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MainContactNameTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MainContactPhoneTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Email:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MainContactEmailTextBox" Margin="0,4,0,4"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                        <CheckBox x:Name="PreferPhoneCheckBox" Content="Prefer Phone" Margin="0,0,12,0"/>
                        <CheckBox x:Name="PreferEmailCheckBox" Content="Prefer Email"/>
                    </StackPanel>

                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="Annual Review Dates" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Future Annual Review:" VerticalAlignment="Center"/>
                        <DatePicker Grid.Column="1" x:Name="FutureAnnualReviewPicker" Margin="0,4,0,4"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Next 3-Year Reevaluation:" VerticalAlignment="Center"/>
                        <DatePicker Grid.Column="1" x:Name="NextThreeYearReevaluationPicker" Margin="0,4,0,4"/>
                    </Grid>

                    <Expander Header="Session History (By Year/Month)" IsExpanded="False" Margin="0,12,0,0">
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" Padding="8" Margin="0,6,0,0">
                            <TreeView x:Name="SessionHistoryTree"/>
                        </Border>
                    </Expander>

                    <Border Margin="0,16,0,0" Padding="10" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Danger Zone" FontWeight="Bold" Foreground="#991B1B"/>
                            <TextBlock x:Name="DeleteInstructionText"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#7F1D1D"
                                       Text="To delete this student, type their full first and last name below exactly as shown."/>
                            <TextBox x:Name="DeleteConfirmationTextBox" Margin="0,8,0,0"/>
                            <Button Content="Delete Student" Width="130" Margin="0,10,0,0" HorizontalAlignment="Left" Click="DeleteStudent_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="100" Height="32" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Save and Exit" Width="120" Height="32" Margin="0,0,8,0" Click="SaveAndExit_Click"/>
            <Button Content="Cancel" Width="100" Height="32" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
