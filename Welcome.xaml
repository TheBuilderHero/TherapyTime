<Window x:Class="TherapyTime.Welcome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome" Height="750" Width="800"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="?" Width="28" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,6"
                Click="HelpBubble_Click"
                ToolTip="Show help for this window"
                FontWeight="Bold" Background="#FEF3C7" BorderBrush="#D97706" Foreground="#92400E"/>
        <Border Grid.Row="1" Background="White"
                CornerRadius="10"
                Padding="30"
                Width="450"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                ShadowDepth="2"
                Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Welcome"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Mode Selection Buttons -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                    <Button x:Name="NewButton"
                            Content="Create New IEP Year"
                            Width="200"
                            Height="40"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="NewButton_Click"
                            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4CAF50"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45A049"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="OpenButton"
                            Content="Open Existing IEP Year"
                            Width="200"
                            Height="40"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2196F3"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1976D2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Panel for Creating New IEP Year -->
                <StackPanel x:Name="NewPanel" Visibility="Visible">
                    <TextBlock Text="School Year Start (YYYY)"
                               FontSize="14"
                               Foreground="#555"
                               Margin="0,0,0,5"/>

                    <TextBox x:Name="SchoolYearTextBox"
                             Height="35"
                             Margin="0,0,0,20"
                             Background="#F0F2F5"
                             BorderBrush="#D0D5DD"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="You will configure all 12 IEP months (start/end dates) in the next step."
                               FontSize="14"
                               Foreground="#555"
                               Margin="0,0,0,20"
                               TextWrapping="Wrap"/>

                    <!-- Submit Button for New -->
                    <Button x:Name="SubmitNew"
                            Content="Configure and Create"
                            Height="40"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Submit_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4CAF50"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45A049"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Panel for Opening Existing IEP Year -->
                <StackPanel x:Name="OpenPanel" Visibility="Collapsed">
                    <TextBlock Text="Select an existing IEP year file:"
                               FontSize="14"
                               Foreground="#555"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="IEPFileList"
                             Height="250"
                             Margin="0,0,0,20"
                             Background="#F0F2F5"
                             BorderBrush="#D0D5DD"
                             MouseDoubleClick="IEPFileList_MouseDoubleClick"/>

                    <!-- Open Button for Existing -->
                    <Button x:Name="SubmitOpen"
                            Content="Open"
                            Height="40"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenSubmit_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2196F3"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1976D2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
