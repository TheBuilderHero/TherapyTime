<Window x:Class="TherapyTime.Welcome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome" Height="450" Width="800"
        Background="#F5F7FA">

    <Grid>
        <Border Background="White"
                CornerRadius="10"
                Padding="30"
                Width="350"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                ShadowDepth="2"
                Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Welcome"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Label -->
                <TextBlock Text="Pick Start Date for IEP"
                           FontSize="14"
                           Foreground="#555"
                           Margin="0,0,0,5"/>

                <!-- DatePicker -->
                <DatePicker x:Name="IEPStartDate"
                            Height="35"
                            Margin="0,0,0,20"
                            Background="#F0F2F5"
                            BorderBrush="#D0D5DD"/>

                <!-- Button -->
                <Button x:Name="Submit"
                        Content="Submit"
                        Height="40"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Submit_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45A049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>