<Window x:Class="TherapyTime.Welcome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TherapyTime"
        mc:Ignorable="d"
        Title="Welcome" Height="450" Width="800">
        
    <StackPanel Name="UserInput" Margin="20" HorizontalAlignment="Left">
        <Label Content="Pick Start Date for IEP:" FontWeight="Bold" />
        
        <DatePicker x:Name="IEPStartDate" 
                    Width="200" 
                    HorizontalAlignment="Left" 
                    Margin="0,5,0,15" />

        <Button x:Name="Submit" 
                Content="Submit Date" 
                Width="100" 
                HorizontalAlignment="Left" 
                Click="Submit_Click" />
    </StackPanel>
</Window>